{
  "name": "nexgenspec-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for NexGenSpec — Apple DeviceCheck trial enforcement",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^13.0.1",
    "firebase-functions": "^6.1.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2",
    "qs": "^6.15.2"
  }
}
