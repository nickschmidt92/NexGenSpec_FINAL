# Secrets — never commit service-account / admin-SDK / OAuth-client keys or .env
# (the committed GoogleService-Info.plist is client config and is fine; these
# guard the genuinely-sensitive files). (audit hardening)
**/serviceAccount*.json
**/*-firebase-adminsdk-*.json
**/client_secret*.json
.env
.env.*

# Apple
.DS_Store
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/

# Xcode build products & caches
build/
DerivedData/
*.xcarchive
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Local scratch / backup dirs
_project_tmp/
_backups/

# Agent / tooling local state
.claude/

# Screenshot fixture: photos are AI-generated and re-generated as needed.
# Keep the directory tracked via .gitkeep but ignore the actual images.
marketing/screenshot-assets/*.jpg
marketing/screenshot-assets/*.png
!marketing/screenshot-assets/.gitkeep

# Live-fetched web pages stored as styling reference, not deliverables
marketing/website-pages/*.reference

# iPhone-audit screenshots: regenerable QA scratch, not deliverables
marketing/iphone-audit/
